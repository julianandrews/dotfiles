#!/usr/bin/env sh

image_file=/tmp/screen_lock.png

generate_screen_shot() {
  resolution=$(xdpyinfo | grep dimensions | awk '{print $2}')
  filters='noise=alls=5,scale=iw*.05:-1,scale=iw*20:-1:flags=neighbor'
  ffmpeg -y -loglevel 0 -s "$resolution" -f x11grab -i $DISPLAY -vframes 1 \
    -vf "$filters" "$image_file"
}

set_lock() {
  i3lock -n -e -i "$image_file" &
}

generate_screen_shot
set_lock
