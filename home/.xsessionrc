# Configure touchpad
if [ hostname = dean ]
then
  xinput set-prop 'SynPS/2 Synaptics TouchPad' 'Synaptics Tap Time' 0
  xinput --set-prop --type=int --format=8 'SynPS/2 Synaptics TouchPad' 'Synaptics Edge Scrolling' 1 0 0
fi

# Setup monitors and load wallpaper.
~/.local/bin/set-monitors &

# Setup screenlock/saver
xset s 300 300
xset dpms 600 900 1200

# urxvt daemon
urxvtd -q -f -o &

# Setup usb automount
devmon --exec-on-drive "notify-send --urgency=normal \"%f mounted to %d.\"" &

# Startup kupfer
kupfer --no-splash > /dev/null &

setxkbmap -option caps:swapescape
