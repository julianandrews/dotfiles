#!/bin/sh

if systemd-creds cat purelymail-app-password 2>/dev/null; then
    :
else
    notification_id=$(fyi -p -i gtk-dialog-authentication "mbsync-pass" "Touch Yubikey to unlock")
    notification_id=${notification_id#id=}
    if pass show personal/purelymail/app-password; then
        fyi -C "$notification_id" 2>/dev/null
    fi
fi
