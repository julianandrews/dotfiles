# --- General Appearance ---
width=400
height=120
border-size=2
padding=12

# Color scheme
background-color=#1a1b26cd
text-color=#c0caf5
border-color=#414868
border-radius=8

# Position and spacing
anchor=top-right
margin=40
font=Monospace 11

# Behavior
default-timeout=5000
layer=overlay

# Critical Notifications
[urgency=critical]
default-timeout=0
border-color=#f7768e
