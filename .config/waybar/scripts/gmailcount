#!/bin/sh

set -e

KEYCTL_DESC="gmailcount"
URL="https://mail.google.com/mail/feed/atom"
CACHE_DIR="${HOME}/.cache/gmailcount"
CACHE_FILE="${CACHE_DIR}/output.json"
PID_FILE="${CACHE_DIR}/pidfile"
POLL_INTERVAL=120
LAUNCHER=chrome-fmgjjmmmlfnkbppncabfkddbjimcfncm-Default 

get_key_id() {
    keyctl search @s user "$KEYCTL_DESC" 2>/dev/null
}

daemon() {
    EMAIL="$1"
    if [ -z "$EMAIL" ]; then
        echo 'Usage: gmailcount daemon <email>'
        exit 0
    fi
    mkdir -p "$CACHE_DIR"
    echo "$$" > "$PID_FILE"

    while [ -f "$PID_FILE" ] && [ "$(cat "$PID_FILE")" -eq $$ ]; do
        fetch_count "$EMAIL" > "$CACHE_FILE"
        sleep "$POLL_INTERVAL"
    done
}

watch() {
    mkdir -p "$CACHE_DIR"
    touch "$CACHE_FILE"
    if ! kill -0 "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null; then
        "$0" daemon "$1" &
        DAEMON_PID=$!
        trap 'kill -- "$DAEMON_PID" 2>/dev/null' EXIT INT TERM HUP
    fi
    inotifywait -q -m -e close_write "$CACHE_FILE" | while read _; do 
        cat "$CACHE_FILE"
    done
}

fetch_count() {
    EMAIL="$1"
    if [ -z "$EMAIL" ]; then
        echo '{"text": "", "tooltip": "Error: email required", "class": "error"}'
        return
    fi

    key_id="$(get_key_id)" || {
        echo '{"text": "", "alt": "locked", "tooltip": "Click to unlock", "class": "locked"}'
        return
    }
    key="$(keyctl pipe "$key_id" 2>/dev/null)" || {
        echo '{"text": "", "alt": "locked", "tooltip": "Click to unlock", "class": "locked"}'
        return
    }
    response="$(curl -s -u "$EMAIL:$key" "$URL" 2>&1)" || {
        echo '{"text": "", "alt": "error", "tooltip": "Network error", "class": "error"}'
        return
    }
    count="$(echo "$response" | grep -oP '<fullcount>\K\d+' || true)"
    if [ -z "$count" ]; then
        echo '{"text": "", "alt": "error", "tooltip": "Invalid response", "class": "error"}'
        return
    fi

    if [ "$count" = "0" ]; then
        echo '{"text": "", "alt": "inbox-empty", "tooltip": "0 unread", "class": "inbox-empty"}'
    else
        echo "{\"text\": \"$count\", \"alt\": \"has-unread\", \"tooltip\": \"$count unread\", \"class\": \"has-unread\"}"
    fi
}

lock() {
    if key_id="$(get_key_id)"; then
        keyctl unlink "$key_id" @s 
        echo '{"text": "", "alt": "locked", "tooltip": "Click to unlock", "class": "locked"}' > "$CACHE_FILE"
        echo "Locked" 
    else 
        echo "Already locked"
    fi
}

unlock() {
    PASS_PATH="$1"
    EMAIL="$2"
    if [ -z "$PASS_PATH" ]; then
        echo 'Usage: gmailcount unlock <pass-path> [<email>]'
        return
    elif get_key_id > /dev/null; then
        echo "Already unlocked"
        return
    else
        notification_id=$(fyi -a gmailcount -p "Unlock Gmail" "Tap your Yubikey" | cut -d= -f2)
        password="$(pass "$PASS_PATH" 2>&1)" || {
            echo "Pass failed"
            return
        }
        fyi --close "$notification_id"
        keyctl add user "$KEYCTL_DESC" "$password" @s > /dev/null
        if ! [ -z "$EMAIL" ]; then
            fetch_count "$EMAIL" > "$CACHE_FILE"
        fi
        echo "Unlocked"
    fi
}

click() {
    if get_key_id; then
        gtk-launch $LAUNCHER
    else
        unlock "$1" "$2"
    fi
}

case "$1" in
    unlock)
        unlock "$2" "$3"
        ;;
    lock)
        lock
        ;;
    click)
        click "$2" "$3"
        ;;
    daemon)
        daemon "$2"
        ;;
    watch)
        watch "$2"
        ;;
    *)
        fetch_count "$1"
        ;;
esac
